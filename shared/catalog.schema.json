{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hefy2027/cf-store/main/catalog.schema.json",
  "title": "CF Store Catalog",
  "description": "CF Manager Store 目录文件的统一校验 Schema。唯一真实来源，backend 与 worker 共用。",
  "type": "object",
  "required": ["version", "templates"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Catalog 版本，语义化版本号"
    },
    "updated": { "type": "string", "description": "ISO 时间字符串" },
    "name": { "type": "string" },
    "defaultLanguage": { "type": "string" },
    "description": { "type": "string", "description": "目录描述（可选元数据）" },
    "mirrorOf": { "type": "string", "format": "uri", "description": "若为镜像源，指向其上游官方源地址（可选元数据，如 surge.sh 备用源）" },
    "templates": {
      "type": "array",
      "items": { "$ref": "#/$defs/template" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "description": "部署源码来源。kind 决定拉取方式，url 为实际拉取地址",
      "required": ["kind", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["raw", "release", "repo-archive"], "description": "部署源码类型：raw 为单文件直链，release 为 GitHub Release 附件，repo-archive 为仓库 ZIP 归档" },
        "url": { "type": "string", "format": "uri", "pattern": "^https://", "description": "部署源码拉取地址。部署时从此处拉取代码；当 homepage 未填时，兜底作为仓库入口" },
        "assetName": { "type": "string" },
        "subPath": { "type": "string" },
        "size": { "type": "number" },
        "mainModule": { "type": "string", "description": "多模块 Worker 入口文件名（如 index.js）。缺省时按约定推断：worker.js → index.js/index.mjs → 根目录首个 JS 模块；有 wrangler.toml/jsonc 时以其中的 main 字段为准。" }
      }
    },
    "binding": {
      "type": "object",
      "required": ["type", "name"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["kv", "d1", "r2", "ai", "var", "durable_object", "service", "queue"] },
        "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "title": { "type": "string", "description": "绑定显示名（自由文本）。" },
        "resourceName": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$", "description": "Cloudflare 资源名（D1/KV/R2）。缺省时用 templateId-bindingName 兜底。" },
        "action": { "enum": ["create-or-reuse", "prompt"] },
        "required": { "type": "boolean" },
        "secret": { "type": "boolean", "description": "仅对 type:var 生效。true/缺省=作为加密 secret 写入（secret_text，前端显示密码框）；false=作为明文环境变量写入（plain_text，前端显示普通文本框）。" },
        "value": { "type": "string", "description": "仅对 type:var 生效。var 的默认值：action=prompt 时前端输入框预填此值，用户未修改则用此值部署；action 非 prompt 时直接使用此值部署。" },
        "initSqlUrl": { "type": "string", "format": "uri" },
        "initSql": { "type": "string" },
        "className": { "type": "string", "description": "DO class 名（仅 durable_object）" },
        "scriptName": { "type": "string", "description": "DO 所在脚本名（跨 Worker 引用，仅 durable_object）" },
        "environment": { "type": "string", "description": "环境名（durable_object / service）" },
        "service": { "type": "string", "description": "目标 Worker 服务名（仅 service）" },
        "entrypoint": { "type": "string", "description": "入口点（仅 service）" },
        "queueName": { "type": "string", "description": "队列名（仅 queue）" },
        "deliveryDelay": { "type": "number", "description": "投递延迟秒数（仅 queue）" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "d1" } },
            "required": ["type"]
          },
          "then": {},
          "else": {
            "not": { "required": ["initSql", "initSqlUrl"] },
            "errorMessage": "initSql / initSqlUrl 仅适用于 d1 绑定"
          }
        }
      ]
    },
    "template": {
      "type": "object",
      "required": ["id", "name", "version", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": {
          "type": "object",
          "description": "作者信息。卡片/详情展示作者时使用 author.name 作为显示名，author.url 作为作者名链接",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "作者显示名" },
            "url": { "type": "string", "format": "uri", "description": "作者个人主页" }
          }
        },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string" },
        "homepage": { "type": "string", "format": "uri", "description": "项目主页/仓库地址。前端用于「访问仓库」按钮及详情页「前往源仓库」链接" },
        "readmeUrl": { "type": "string", "format": "uri", "description": "README 原始内容地址（如 raw.githubusercontent.com），详情页加载 README 时使用" },
        "type": { "enum": ["worker", "pages", "hybrid"] },
        "compatibility_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "Worker 兼容性日期。缺省时部署端使用较新的安全默认值（'2024-11-01'）。React Router v7 / 含 node 构建产物的 worker 通常需要更新的日期。" },
        "compatibility_flags": {
          "type": "array",
          "description": "Worker 兼容性标志，如 [\"nodejs_compat\"]。含 CJS 互操作（require/__commonJS）或访问 process/Buffer 等 node 内置的 worker 必须开启 nodejs_compat，否则运行时抛异常（Error 1101）。",
          "items": { "type": "string" }
        },
        "source": { "$ref": "#/$defs/source", "description": "部署源码（非 hybrid 类型使用）。当 homepage 未填时，source.url 兜底作为仓库入口" },
        "sources": {
          "type": "object",
          "description": "hybrid 类型的部署源码集合，同时包含 worker 和/或 pages 源",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "worker": { "$ref": "#/$defs/source" },
            "pages": { "$ref": "#/$defs/source" }
          }
        },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/binding" }
        },
        "env": { "type": "object" },
        "routes": { "type": "array", "items": { "type": "string" } },
        "crons": {
          "type": "array",
          "description": "Worker 定时任务（Cron Triggers）。每个元素是标准 cron 表达式（如 \"*/5 * * * *\"），部署后自动注册到该 Worker 脚本。仅对 worker/hybrid(worker 部分) 生效；pages 类型不适用（Cron 绑定在 Worker 脚本而非 Pages 项目）。",
          "items": { "type": "string", "pattern": "^\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+$" }
        },
        "assets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source"],
          "properties": {
            "source": { "$ref": "#/$defs/source" },
            "binding": { "type": "string", "description": "资产绑定变量名，默认 ASSETS" },
            "config": {
              "type": "object",
              "properties": {
                "html_handling": { "type": "string" },
                "not_found_handling": { "type": "string" }
              }
            }
          }
        },
        "migrations": {
          "type": "array",
          "description": "Durable Object 迁移配置。按顺序执行，每个 tag 代表一次迁移。",
          "items": {
            "type": "object",
            "required": ["tag"],
            "additionalProperties": false,
            "properties": {
              "tag": { "type": "string" },
              "new_classes": { "type": "array", "items": { "type": "string" } },
              "renamed_classes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["from", "to"],
                  "additionalProperties": false,
                  "properties": {
                    "from": { "type": "string" },
                    "to": { "type": "string" }
                  }
                }
              },
              "deleted_classes": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "keep_vars": {
          "type": "boolean",
          "default": true,
          "description": "部署时保留已有的明文环境变量。默认 true（更安全）。"
        },
        "keep_secrets": {
          "type": "boolean",
          "default": true,
          "description": "部署时保留已有的加密 Secrets。默认 true（更安全）。"
        },
        "keep_bindings": {
          "type": "boolean",
          "default": true,
          "description": "部署时保留已有的非 var/secret 绑定（KV、D1、R2 等）。默认 true（更安全）。wrangler 对应 metadata.keep_bindings 字段。"
        },
        "placement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "enum": ["smart", "off"] }
          }
        },
        "tail_consumers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["service"],
            "additionalProperties": false,
            "properties": {
              "service": { "type": "string" },
              "environment": { "type": "string" }
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu_ms": { "type": "number" },
            "memory_mb": { "type": "number" }
          }
        },
        "logpush": { "type": "boolean", "default": false }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "hybrid" } },
            "required": ["type"]
          },
          "then": {
            "required": ["sources"],
            "not": { "required": ["source"] },
            "errorMessage": {
              "required": { "sources": "hybrid 类型需要 sources 字段（worker/pages 二选一或都有）" },
              "not": "hybrid 类型不能使用 source 字段，请用 sources"
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": { "type": { "const": "hybrid" } },
              "required": ["type"]
            }
          },
          "then": {
            "required": ["source"],
            "not": { "required": ["sources"] },
            "errorMessage": {
              "required": { "source": "worker/pages 类型需要 source 字段" },
              "not": "非 hybrid 类型不能使用 sources 字段"
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "pages" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "source": {
                "properties": {
                  "kind": {
                    "not": { "enum": ["raw"] },
                    "errorMessage": "pages 类型不能使用 raw 源（Pages 需要 zip）"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "worker" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "source": {
                "properties": {
                  "kind": {
                    "not": { "enum": ["repo-archive"] },
                    "errorMessage": "worker 类型不能使用 repo-archive 源（单脚本）"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "pages" } },
            "required": ["type"]
          },
          "then": {
            "not": { "required": ["crons"] },
            "errorMessage": {
              "not": "pages 类型不支持 crons（定时任务是 Worker 脚本特性）"
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "hybrid" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "sources": {
                "properties": {
                  "pages": {
                    "properties": {
                      "kind": {
                        "not": { "enum": ["raw"] },
                        "errorMessage": "sources.pages 不能使用 raw 源（Pages 需要 zip）"
                      }
                    }
                  },
                  "worker": {
                    "properties": {
                      "kind": {
                        "not": { "enum": ["repo-archive"] },
                        "errorMessage": "sources.worker 不能使用 repo-archive 源（单脚本）"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
